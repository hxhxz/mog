{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project Context",
  "description": "PRD §3.3 项目级 Context 对象",
  "type": "object",
  "required": ["project_id"],
  "properties": {
    "project_id": { "type": "string" },
    "style_lora": { "type": ["string", "null"] },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "reference_image_url": { "type": ["string", "null"] },
          "character_lora_id": { "type": ["string", "null"] }
        }
      }
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "order_index", "status"],
        "properties": {
          "id": { "type": "string" },
          "order_index": { "type": "integer" },
          "status": { "type": "string" },
          "storyboard_url": { "type": ["string", "null"] },
          "video_url": { "type": ["string", "null"] }
        }
      }
    },
    "audio_track": { "type": ["string", "null"] }
  }
}
