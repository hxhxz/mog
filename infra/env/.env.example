# Copy to infra/env/.env

APP_ENV=dev
LOG_LEVEL=INFO

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mog
POSTGRES_PASSWORD=mog
POSTGRES_DB=mog

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ComfyUI
COMFYUI_HOST=comfyui
COMFYUI_PORT=8188

# Agent / Model
AGENT_SERVICE_URL=http://agent:8100
MODEL_NAME=anthropic/claude-sonnet-4-5
MODEL_API_KEY=

# Aliyun OSS (optional — leave empty to use local stub)
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
